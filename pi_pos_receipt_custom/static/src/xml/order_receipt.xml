<?xml version="1.0" encoding="UTF-8" ?>
<templates id="template" xml:space="preserve">
    <t t-name="ReceiptQuotation" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//ReceiptHeader" position="after">
            <p t-if="props.data.isBill and props.data.isQuotation" class="text-center" style="background: black;text-align: center;color: white;">
                Cotizacion
            </p>
        </xpath>
    </t>
    <t t-name="pi_pos_receipt_custom.ControlButtons" t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension">
        <xpath expr="//t[@t-if='props.showRemainingButtons']/div/OrderlineNoteButton" position="after">
            <t t-if="pos.config.iface_printbill">
                <button t-att-class="buttonClass"
                    t-att-disabled="!pos.get_order()?.get_orderlines()?.length"
                    t-on-click="clickPrintBill">
                    <i class="fa fa-print me-1"></i>Pre imprimir
                </button>
            </t>
            <button t-att-class="buttonClass"
                t-att-disabled="!pos.get_order()?.get_orderlines()?.length"
                t-on-click="clickPrintQuotation">
                <i class="fa fa-print me-1"></i>Cotizacion
            </button>
        </xpath>
    </t>    

</templates>
