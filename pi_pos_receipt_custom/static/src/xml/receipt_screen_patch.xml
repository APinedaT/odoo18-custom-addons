<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pi_pos_receipt_custom.ReceiptScreenPatch" t-inherit="point_of_sale.ReceiptScreen" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('d-flex','gap-1')][button[hasclass('print')]]" position="inside">
            <button class="button btn btn-lg btn-secondary w-100 py-3" t-on-click="downloadImage">
                <i class="fa fa-download me-1" />Descargar Imagen
            </button>
        </xpath>
    </t>
</templates>
